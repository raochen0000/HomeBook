{
  "name": "homebook",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "expo-image"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:sim": "open -a Simulator; xcodebuild -workspace ios/HomeBook.xcworkspace -scheme HomeBook -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath ios/build CODE_SIGNING_ALLOWED=NO build && xcrun simctl install booted ios/build/Build/Products/Debug-iphonesimulator/HomeBook.app && xcrun simctl launch --terminate-running-process booted com.raochen.homebook-app",
    "ios:sim:clean": "EXPO_USE_PRECOMPILED_MODULES=false LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 pod install --project-directory=ios && rm -rf ios/build/Build && npm run ios:sim",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "expo lint --fix"
  },
  "dependencies": {
    "@expo/ui": "56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "56.0.8",
    "expo-apple-authentication": "~56.0.4",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "56.0.16",
    "expo-dev-client": "56.0.18",
    "expo-device": "56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "56.0.5",
    "expo-glass-effect": "56.0.4",
    "expo-image": "56.0.6",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "56.0.13",
    "expo-media-library": "~56.0.7",
    "expo-notifications": "~56.0.19",
    "expo-router": "56.2.8",
    "expo-splash-screen": "56.0.10",
    "expo-status-bar": "56.0.4",
    "expo-symbols": "56.0.5",
    "expo-system-ui": "56.0.5",
    "expo-web-browser": "56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/react": "19.2.16",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  }
}
