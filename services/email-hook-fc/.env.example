# 家账 · 邮件 Hook（FC）环境变量。复制为 FC 函数的环境变量配置，勿提交真实值。

# —— 阿里云邮件推送（DirectMail / SingleSendMail）——
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 控制台「邮件推送 → 发信地址」里创建的发信地址（addressType=1）
DM_ACCOUNT_NAME=no-reply@homebook-app.com
# 发件人昵称（收件箱里显示的名字），默认「家账」
# DM_FROM_ALIAS=家账
# 可选：接入点，默认 dm.aliyuncs.com（中国区通用）
# DM_ENDPOINT=dm.aliyuncs.com

# —— GoTrue Send Email Hook 共享密钥（与 GOTRUE_HOOK_SEND_EMAIL_SECRETS 完全一致）——
# 形如：v1,whsec_BASE64...
HOOK_SECRET=

# —— 与 GoTrue 邮件 OTP 有效期一致（可选，默认 3600 秒，用于正文里的「N 分钟内有效」）——
# EMAIL_OTP_EXP=3600
