# 家账 · 推送投递（FC 定时轮询）环境变量。复制为 FC 函数的环境变量配置，勿提交真实值。

# —— Supabase（service_role，绕 RLS 读通知/偏好/令牌、标记已推、清失效令牌）——
# 与客户端 EXPO_PUBLIC_SUPABASE_URL 同一实例地址（REST 走 443，不受 5432 端口封锁影响）
SUPABASE_URL=https://your-instance.example.com
# service_role 密钥（高权限，务必只放在 FC 环境变量里，切勿进仓库/客户端）
SUPABASE_SERVICE_ROLE_KEY=

# —— 可选 ——
# 只推最近 N 分钟内产生的通知（默认 360=6h）；防 FC 长时间宕机后补推过旧通知刷屏
# PUSH_LOOKBACK_MINUTES=360
# 单轮最多处理条数（默认 200）
# PUSH_BATCH_LIMIT=200
# 若在 Expo 后台开启了「Enhanced Security for Push」，填 Expo 访问令牌；默认不需要
# EXPO_ACCESS_TOKEN=
