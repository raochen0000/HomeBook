# 家账 · 短信 Hook（FC）环境变量。复制为 FC 函数的环境变量配置，勿提交真实值。

# —— 阿里云短信认证（dypnsapi）——
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 控制台「短信认证 → 签名管理」里系统赠送的签名名称
SMS_SIGN_NAME=
# 控制台「短信认证 → 模板管理」里系统赠送的模板 CODE（登录/注册用 100001）
SMS_TEMPLATE_CODE=100001
# 可选：接入点，默认 dypnsapi.aliyuncs.com
# ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
# 可选：默认已自动填 code+min（min=SMS_OTP_EXP/60，即 5），匹配系统赠送模板；
# 仅当你的模板变量不同才需覆盖，用 {code} 占位 OTP，例如只含 code：{"code":"{code}"}
# SMS_TEMPLATE_PARAM={"code":"{code}","min":"5"}

# —— GoTrue Send SMS Hook 共享密钥（与 GOTRUE_HOOK_SEND_SMS_SECRETS 完全一致）——
# 形如：v1,whsec_BASE64...
HOOK_SECRET=

# —— 与 GoTrue 保持一致（可选，默认 300 秒）——
# SMS_OTP_EXP=300
